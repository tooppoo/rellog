{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tooppoo/rellog/schema/entry.schema.json",
  "title": "rellog entry",
  "description": "Schema for one pending rellog changelog entry.",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "targets", "links", "body"],
  "allOf": [
    {
      "if": {
        "required": ["kind"],
        "properties": {
          "kind": {
            "const": "empty"
          }
        }
      },
      "then": {
        "properties": {
          "targets": {
            "maxItems": 0
          },
          "links": {
            "maxItems": 0
          }
        }
      }
    }
  ],
  "properties": {
    "kind": {
      "type": "string"
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri",
        "pattern": "^https?://[^\\s/$.?#].*"
      }
    },
    "body": {
      "type": "string"
    }
  }
}
