exec sh -c 'git init && git remote add origin https://github.com/tooppoo/rellog'


exec rellog init

! exec rellog check
! stdout .
cmp stderr expected.txt

-- .rellog/config.kdl --
/- kdl-version 1

-- expected.txt --
rellog check: FAILED

1 files
1 errors

.rellog/config.kdl
  error[kdl-version.unsupported]
    rellog supports only KDL v2
