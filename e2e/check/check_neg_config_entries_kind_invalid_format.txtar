cmp stderr rellog.entries.kinds.trailing_hyphen.expected.txt

mv rellog.entries.kinds.space.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr rellog.entries.kinds.space.expected.txt

mv rellog.entries.kinds.slash.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr rellog.entries.kinds.slash.expected.txt

-- rellog.entries.kinds.multibyte.kdl --
/- kdl-version 2

rellog config-version=1 {
  paths {
    changelog "CHANGELOG.md"
    entries ".rellog/entries"
    release-notes ".rellog/release-notes"
  }

  entries {
    kinds {
      kind "add"
      kind "change"
      kind "テスト" // invalid
    }

    targets {
      target "cli"
    }

  }
}
-- rellog.entries.kinds.multibyte.expected.txt --
rellog check: FAILED

1 files
1 errors

.rellog/config.kdl
  error[rellog.entries.kinds.kind.id.invalid]
    The kind id "テスト" is invalid.

    kind id must match /[A-Za-z][a-z0-9]*(?:-[a-z0-9]+)*/
