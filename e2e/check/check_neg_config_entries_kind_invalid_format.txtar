exec sh -c 'git init && git remote add origin https://github.com/tooppoo/rellog'

exec rellog init

mv rellog.entries.kinds.multibyte.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr rellog.entries.kinds.multibyte.expected.txt

mv rellog.entries.kinds.number_head.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr rellog.entries.kinds.number_head.expected.txt

mv rellog.entries.kinds.underscore_head.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr rellog.entries.kinds.underscore_head.expected.txt

mv rellog.entries.kinds.hyphen_head.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr rellog.entries.kinds.hyphen_head.expected.txt

mv rellog.entries.kinds.dot_head.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr rellog.entries.kinds.dot_head.expected.txt

mv rellog.entries.kinds.underscore_mid.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr rellog.entries.kinds.underscore_mid.expected.txt

mv rellog.entries.kinds.camelcase.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr rellog.entries.kinds.camelcase.expected.txt

mv rellog.entries.kinds.trailing_hyphen.kdl .rellog/config.kdl
! exec rellog check
