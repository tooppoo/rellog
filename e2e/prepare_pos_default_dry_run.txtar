
exec rellog init
! stderr .
! exists CHANGELOG.md

exec rellog add --kind changed --target rellog --body 'Previewed entry'
! stderr .

exec rellog prepare v1.0.0
stdout '## v1\.0\.0'
stdout 'Previewed entry'
stdout 'create .rellog/release-notes/v1\.0\.0\.md'
stdout 'append CHANGELOG\.md'
stdout 'delete .rellog/entries/0001\.md'
! stderr .

! exists .rellog/release-notes/v1.0.0.md
! exists .rellog/release-notes/v1.0.0.json
! exists CHANGELOG.md
exists .rellog/entries/0001.md
