
exec rellog init
! stderr .

exec rellog add-empty
! stderr .
exists .rellog/entries/0001.md

exec sh -c 'rellog add --kind changed --target rellog --body "Normal entry"; test "$?" -eq 5'
! stdout .
stderr 'Error: entry conflict: empty entry already exists; normal entry cannot be added\n'

cmp .rellog/entries/0001.md .rellog.expected/entries/0001.md
! exists .rellog/entries/0002.md

-- .rellog.expected/entries/0001.md --
---
kind: empty
---

No changelog-worthy changes.
