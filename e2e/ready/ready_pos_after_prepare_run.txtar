exec rellog init
! stderr .

exec rellog add --debug-datetime 20260626T123456.000000001Z --kind changed --target rellog --body 'Ready entry'
! stderr .

exec rellog prepare v1.0.0 --run
stdout 'v1\.0\.0 release prepared\n'
! stderr .

exec rellog ready v1.0.0
cmp stdout expected.stdout
! stderr .

-- expected.stdout --
v1.0.0 release ready
