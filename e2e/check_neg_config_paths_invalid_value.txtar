
exec rellog init
! stderr .

## paths
mv paths.not-block.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr paths.not-block.expected.txt

mv paths.empty.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr paths.empty.expected.txt

## paths.changelog
mv paths.changelog.empty.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr paths.changelog.empty.expected.txt

mv paths.changelog.blank.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr paths.changelog.blank.expected.txt

mv paths.changelog.emtpy_string.kdl .rellog/config.kdl
