-- paths.changelog.children.kdl --
rellog config-version=1 {
  paths {
    changelog "CHANGELOG.md" {
      format "markdown"
    }
    entries ".rellog/entries"
    release-notes ".rellog/release-notes"
  }
}
-- paths.changelog.children.expected.txt --
rellog check: FAILED

1 files
1 errors

.rellog/config.kdl
  error[rellog.paths.changelog.unexpected_children]
    rellog.paths.changelog must not have child nodes.
