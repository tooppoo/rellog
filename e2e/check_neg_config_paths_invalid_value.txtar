! stdout .
cmp stderr paths.entries.empty.children.expected.txt

## paths.release-notes
mv paths.release-notes.empty.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr paths.release-notes.empty.expected.txt

mv paths.release-notes.empty_string.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr paths.release-notes.empty_string.expected.txt

mv paths.release-notes.empty.blank.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr paths.release-notes.empty.blank.expected.txt

mv paths.release-notes.empty.multibyte_blank.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr paths.release-notes.empty.multibyte_blank.expected.txt

mv paths.release-notes.empty.mixed_blank.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr paths.release-notes.empty.mixed_blank.expected.txt

mv paths.release-notes.empty.children.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr paths.release-notes.empty.children.expected.txt

-- paths.not-block.kdl --
rellog config-version=1 {
  paths "some-path-value"
}
-- paths.not-block.expected.txt --
rellog check: FAILED

1 files
1 errors

.rellog/config.kdl
  error[rellog.paths.missing]
    rellog.paths must be a block, but found a value
-- paths.empty.kdl --
rellog config-version=1 {
  paths {
  }
}
-- paths.empty.expected.txt --
rellog check: FAILED

1 files
3 errors

.rellog/config.kdl
  error[rellog.paths.changelog.missing]
    rellog.paths.changelog is required but not found

  error[rellog.paths.entries.missing]
    rellog.paths.entries is required but not found

  error[rellog.paths.release-notes.missing]
    rellog.paths.release-notes is required but not found
-- paths.changelog.empty.kdl --
rellog config-version=1 {
  paths {
    changelog
    entries ".rellog/entries"
    release-notes ".rellog/release-notes"
  }
}
-- paths.changelog.empty.expected.txt --
rellog check: FAILED

1 files
1 errors

.rellog/config.kdl
  error[rellog.paths.changelog.empty]
    rellog.paths.changelog value cannot be empty.
-- paths.changelog.blank.kdl --
rellog config-version=1 {
  paths {
    changelog "   "
    entries ".rellog/entries"
    release-notes ".rellog/release-notes"
  }
}
-- paths.changelog.blank.expected.txt --
rellog check: FAILED

1 files
1 errors

.rellog/config.kdl
  error[rellog.paths.changelog.empty]
    rellog.paths.changelog value cannot be empty.
