! stdout .
cmp stderr paths.changelog.emtpy_string.expected.txt

mv paths.changelog.multibyte_blank.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr paths.changelog.multibyte_blank.expected.txt

mv pahs.changelog.mixed_blank.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr pahs.changelog.mixed_blank.expected.txt

mv paths.changelog.children.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr paths.changelog.children.expected.txt

## paths.entries
mv paths.entries.empty.kdl .rellog/config.kdl
