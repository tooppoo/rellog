exec sh -c 'git init && git remote add origin https://github.com/tooppoo/rellog'

exec rellog init
! stderr .

stdin answers.txt
! exec rellog add
stderr 'kind "experimental" is not defined in rellog.entries.kinds\.'
exec sh -c 'test -z "$(ls .rellog/entries)"'

-- answers.txt --
experimental
rellog
Unknown kind
