mv rellog.entries.kinds.slash.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr rellog.entries.kinds.slash.expected.txt

-- rellog.entries.kinds.multibyte.kdl --
/- kdl-version 2

rellog config-version=1 {
  paths {
    changelog "CHANGELOG.md"
    entries ".rellog/entries"
    release-notes ".rellog/release-notes"
  }

  entries {
    kinds {
      kind "add"
      kind "change"
      kind "テスト" // invalid
    }

    target-policy "allow-unknown"
  }
}
-- rellog.entries.kinds.multibyte.expected.txt --
rellog check: FAILED

1 files
1 errors

.rellog/config.kdl
  error[config.entries.kinds.invalid_format]
    The kind value "テスト" is invalid.

    kind value is identifier.
    it must satisfy /^[a-z][0-9a-zA-Z_-.]+$/
