
exec rellog init

mv rellog.entries.kinds.multibyte.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr rellog.entries.kinds.multibyte.expected.txt

mv rellog.entries.kinds.uppercase_head.kdl .rellog/config.kdl
! exec rellog check
! stdout .
cmp stderr rellog.entries.kinds.uppercase_head.expected.txt

mv rellog.entries.kinds.number_head.kdl .rellog/config.kdl
