
exec rellog init
! stderr .
! cmp .rellog/config.kdl default-config.kdl

-- .rellog/config.kdl --
/- kdl-version 2

rellog config-version=1 {
  github-url "https://github.com/tooppoo/rellog"
  paths {
    entry_dir ".rellog-test/entries"
    release_note_dir ".rellog-test/release_notes"
  }
}
-- default-config.kdl --
/- kdl-version 2
