exec rellog init
! stderr .

! exec rellog add --kind changed --target rellog --issue https://github.com/other/repo/issues/12 --body 'Wrong issue repository'
stderr 'issue URL repository "https://github.com/other/repo" does not match github-url "https://github.com/tooppoo/rellog"'
exec sh -c 'test -z "$(ls .rellog/entries)"'

! exec rellog add --kind changed --target rellog --pr https://github.com/other/repo/pull/15 --body 'Wrong PR repository'
stderr 'pull request URL repository "https://github.com/other/repo" does not match github-url "https://github.com/tooppoo/rellog"'
exec sh -c 'test -z "$(ls .rellog/entries)"'

! exec rellog add --kind changed --target rellog --issue https://github.com/tooppoo/rellog/pull/12 --body 'Issue path is pull'
stderr 'pull request URL was passed to --issue; use --pr for https://github.com/tooppoo/rellog/pull/12'
exec sh -c 'test -z "$(ls .rellog/entries)"'

! exec rellog add --kind changed --target rellog --pr https://github.com/tooppoo/rellog/issues/15 --body 'PR path is issue'
stderr 'issue URL was passed to --pr; use --issue for https://github.com/tooppoo/rellog/issues/15'
exec sh -c 'test -z "$(ls .rellog/entries)"'

! exec rellog add --kind changed --target rellog --issue https://example.com/tooppoo/rellog/issues/12 --body 'Wrong host'
stderr 'issue URL host must be github.com'
exec sh -c 'test -z "$(ls .rellog/entries)"'

! exec rellog add --kind changed --target rellog --issue https://github.com/tooppoo/rellog/issues/12/ --body 'Trailing slash'
stderr 'issue URL must be canonical and must not have a trailing slash'
exec sh -c 'test -z "$(ls .rellog/entries)"'

! exec rellog add --kind changed --target rellog --issue https://github.com/tooppoo/rellog/issues/12?x=1 --body 'Query'
stderr 'issue URL must be canonical and must not include query or fragment'
exec sh -c 'test -z "$(ls .rellog/entries)"'

! exec rellog add --kind changed --target rellog --issue 'https://github.com/tooppoo/rellog/issues/12#discussion' --body Fragment
stderr 'issue URL must be canonical and must not include query or fragment'
exec sh -c 'test -z "$(ls .rellog/entries)"'

! exec rellog add --kind changed --target rellog --issue https://github.com/tooppoo/rellog/pull/12 --pr https://github.com/other/repo/pull/15 --issue https://example.com/tooppoo/rellog/issues/16 --body 'Multiple invalid references'
stderr 'pull request URL was passed to --issue; use --pr for https://github.com/tooppoo/rellog/pull/12'
stderr 'pull request URL repository "https://github.com/other/repo" does not match github-url "https://github.com/tooppoo/rellog"'
stderr 'issue URL host must be github.com'
exec sh -c 'test -z "$(ls .rellog/entries)"'

! exec rellog add --kind changed --target rellog --issue https://github.com/other/repo/pull/12 --pr https://github.com/other/repo/issues/15 --body 'Wrong type and wrong repository'
stderr 'pull request URL was passed to --issue; use --pr for https://github.com/other/repo/pull/12'
stderr 'pull request URL repository "https://github.com/other/repo" does not match github-url "https://github.com/tooppoo/rellog"'
stderr 'issue URL was passed to --pr; use --issue for https://github.com/other/repo/issues/15'
stderr 'issue URL repository "https://github.com/other/repo" does not match github-url "https://github.com/tooppoo/rellog"'
exec sh -c 'test -z "$(ls .rellog/entries)"'

exec cp missing_github_url.kdl .rellog/config.kdl
! exec rellog add --kind changed --target rellog --issue 12 --body 'Missing github-url'
stderr 'github-url is required in .rellog/config.kdl'
exec sh -c 'test -z "$(ls .rellog/entries)"'

-- missing_github_url.kdl --
/- kdl-version 2

rellog config-version=1 {
  paths {
    changelog "CHANGELOG.md"
    entries ".rellog/entries"
    release-notes ".rellog/release-notes"
  }

  entries {
    target-policy "allow-unknown"

    kinds {
      kind "changed"
    }
  }
}
