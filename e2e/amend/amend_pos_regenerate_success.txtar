exec sh -c 'git init && git remote add origin https://github.com/tooppoo/rellog'

exec rellog init
! stderr .

exec rellog add --debug-datetime 20260626T123456.000000001Z --kind changed --target rellog --body 'First entry'
! stderr .

exec rellog prepare v1.0.0 --run
! stderr .

exec rellog add --debug-datetime 20260627T123456.000000001Z --kind fixed --target rellog --body 'Second entry'
! stderr .

exec rellog amend v1.0.0 --run
cmp stdout expected.stdout
! stderr .

! exists .rellog/entries/20260627T123456.000000001Z.json
cmp .rellog/release-notes/v1.0.0.md expected.release-note.md

exists .rellog/consumed/v1.0.0/entries/20260626T123456.000000001Z.json
exists .rellog/consumed/v1.0.0/entries/20260627T123456.000000001Z.json
cmp .rellog/consumed/v1.0.0/manifest.json expected.manifest.json

-- expected.stdout --
v1.0.0 release amended
-- expected.release-note.md --
## v1.0.0

### changed

#### Details

<!-- rellog:body:start -->
First entry
<!-- rellog:body:end -->

#### Targets

- rellog

### fixed

#### Details

<!-- rellog:body:start -->
Second entry
<!-- rellog:body:end -->

#### Targets

- rellog
-- expected.manifest.json --
{
  "schemaVersion": 1,
  "releaseId": "v1.0.0",
  "entries": [
    {
      "filename": "20260626T123456.000000001Z.json"
    },
    {
      "filename": "20260627T123456.000000001Z.json"
    }
  ]
}
